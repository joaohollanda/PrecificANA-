<Window x:Class="PrecificAna.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PrecificAna"
        mc:Ignorable="d"
        Title="PrecificANA!" Height="530" Width="400">

    <Grid>
        <TabControl>
            <TabItem Header="Calculadora">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="PrecificAPP!" 
                                   FontSize="20" 
                                   FontWeight="Bold" Margin="0,0,0,0" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="by ceramicANA!" 
                                   FontSize="10" 
                                   FontWeight="ExtraLight" Margin="50,0,0,15" 
                                   HorizontalAlignment="Center"/>

                        <Label Content="1. Peso da Peça Seca (gramas):" 
                               Target="{Binding ElementName=txtPesoSeco}"
                               HorizontalAlignment="Center"/>
                               
                        <TextBox x:Name="txtPesoSeco" 
                                 Text="{Binding PesoSeco, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,10" 
                                 Width="167" 
                                 HorizontalAlignment="Center" />

                        <Label Content="2. Tempo de produção (minutos):"
                               Target="{Binding ElementName=txtTempo}"
                               HorizontalAlignment="Center"/>
                        <TextBox x:Name="txtTempo" 
                                 Text="{Binding TempoMinutos, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,10"
                                 Width="167" 
                                 HorizontalAlignment="Center" />

                        <Label Content="3. Esmalte Líquido Usado (gramas):" 
                               Target="{Binding ElementName=txtEsmalteUsado}"
                               HorizontalAlignment="Center"/>
                        <TextBox x:Name="txtEsmalteUsado" 
                                 Text="{Binding GramasEsmalte, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,10" 
                                 Width="167" 
                                 HorizontalAlignment="Center" />

                        <Label Content="4. Peso Esmaltado Final (gramas):" 
                               Target="{Binding ElementName=txtPesoAlta}"
                               HorizontalAlignment="Center"/>
                        <TextBox x:Name="txtPesoAlta" 
                                 Text="{Binding PesoEsmaltado, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,10" Width="167"
                                 HorizontalAlignment="Center" />

                        <Separator Margin="0,15,0,15" />

                        <TextBlock Text="Preço Final Estimado (com lucro):" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,0" />

                        <TextBlock Text="{Binding PrecoFinal}" 
                                   FontSize="20" 
                                   FontWeight="DemiBold" 
                                   Foreground="#2E7D32" 
                                   HorizontalAlignment="Center"/>
                        
                        <Separator Margin="0,15,0,15" />
                        <TextBlock Text="Custos individuais:" 
                                   HorizontalAlignment="Center"
                                   Margin="10,0,0,10" />

                        <UniformGrid Columns="2" Margin="0,0,0,0" HorizontalAlignment="Center">
                            <TextBlock Text="Argila: R$50,99 " Margin="0,0,0,0" />
                            <TextBlock Text="Tempo: R$10,00 " Margin="0,0,0,0" />
                            <TextBlock Text="Esmalte: R$15,00 " Margin="0,0,0,0" />
                            <TextBlock Text="Queima biscoito: R$5,50 " Margin="0,0,0,0" />
                            <TextBlock Text="Queima alta: R$5,50 " Margin="0,0,0,0" />
                        </UniformGrid>
                        

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Configurações">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Configurações de Preços" 
                               FontSize="18" 
                               FontWeight="Bold" />

                        <Label Content="Valor da argila (R$/kg):" 
                           Target="{Binding ElementName=txtPrecoArgilaKg}"/>

                        <TextBox x:Name="txtPrecoArgilaKg" 
                                 Text="{Binding PrecoArgilaKg, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                        <Label Content="Preço queima de biscoito (R$/kg):" 
                           Target="{Binding ElementName=txtPrecoQueimaBiscoito}"/>

                        <TextBox x:Name="txtPrecoQueimaBiscoito" 
                                 Text="{Binding PrecoQueimaBiscoitoKg, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                        <Label Content="Preço queima de esmalte (R$/kg):" 
                           Target="{Binding ElementName=txtPrecoQueimaAlta}"/>

                        <TextBox x:Name="txtPrecoQueimaAlta" 
                                 Text="{Binding PrecoQueimaEsmalteKg, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                        <Label Content="Preço do pote de esmalte (R$):" 
                           Target="{Binding ElementName=txtPrecoPoteEsmalte}"/>

                        <TextBox x:Name="txtPrecoPoteEsmalte" 
                                 Text="{Binding PrecoPoteEsmalte, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                        <Label Content="Peso do pote de esmalte (gramas):" 
                           Target="{Binding ElementName=txtPesoPoteEsmalteGramas}"/>

                        <TextBox x:Name="txtPesoPoteEsmalteGramas" 
                                 Text="{Binding PesoPoteEsmalteGramas, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                        <Label Content="Valor da hora de trabalho (R$):" 
                           Target="{Binding ElementName=txtValorHoraTrabalho}"/>

                        <TextBox x:Name="txtValorHoraTrabalho" 
                                 Text="{Binding ValorHoraTrabalho, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                        <Label Content="Margem de lucro (%):" 
                           Target="{Binding ElementName=txtMargemLucroPorcentagem}"/>

                        <TextBox x:Name="txtMargemLucroPorcentagem" 
                                 Text="{Binding MargemLucroPorcentagem, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Margin="6,0,0,0" 
                                 Width="120" 
                                 HorizontalAlignment="Left" />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>